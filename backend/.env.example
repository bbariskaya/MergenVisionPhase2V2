# Local development placeholders.
# Copy this file to backend/.env; docker-compose also loads backend/.env.

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=mergenvision
POSTGRES_USER=mergenvision
POSTGRES_PASSWORD=mergenvision
DATABASE_URL=postgresql+asyncpg://mergenvision:mergenvision@localhost:5433/mergenvision

# MinIO
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_NAME=mergenvision-face-samples

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6335
QDRANT_URL=http://localhost:6335
QDRANT_COLLECTION_NAME=face_samples_retinaface_r50_glintr100_v1

# Model / embedding version label stored in Qdrant payload.
MODEL_VERSION=retinaface_r50_glintr100_v1

# Native GPU inference
MODEL_PROFILE_PATH=backend/config/model_profiles/retinaface_r50_glintr100_v1.example.json
DETECTOR_ENGINE_PATH=backend/artifacts/engines/retinaface_r50_dynamic.bs1.opt8.max64.fp16.trt1016.engine
RECOGNIZER_ENGINE_PATH=backend/artifacts/engines/glintr100.bs1.opt8.max64.fp16.trt1016.engine
GPU_DEVICE_ID=0
INFERENCE_SLOT_COUNT=1
MATCH_THRESHOLD=0.55
MAX_IMAGE_BYTES=26214400

# Application
LOG_LEVEL=INFO
