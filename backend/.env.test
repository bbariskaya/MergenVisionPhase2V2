# Dedicated test environment for Phase 1 Sprint 01 acceptance.
# Copy this file to backend/.env.test before running acceptance targets.

MV_TEST_MODE=1
MV_TEST_RESOURCE_NAMESPACE=mergenvision-s01-test

# PostgreSQL (dedicated test instance)
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=mergenvision_s01_test
POSTGRES_USER=mergenvision_test
POSTGRES_PASSWORD=mergenvision_test
DATABASE_URL=postgresql+asyncpg://mergenvision_test:mergenvision_test@localhost:55432/mergenvision_s01_test

# MinIO (dedicated test instance)
MINIO_ENDPOINT=localhost:59000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_NAME=mergenvision-s01-test-face-samples

# Qdrant (dedicated test instance)
QDRANT_URL=http://localhost:56333
QDRANT_COLLECTION_NAME=mergenvision_s01_test_face_samples_v1

# Model / embedding version label stored in Qdrant payload.
MODEL_VERSION=phase1-sprint-01-test

# Native GPU inference (paths relative to backend/ test cwd)
MODEL_PROFILE_PATH=config/model_profiles/retinaface_r50_glintr100_v1.example.json
DETECTOR_ENGINE_PATH=artifacts/engines/retinaface_r50_dynamic.bs1.opt8.max64.fp16.trt1016.engine
RECOGNIZER_ENGINE_PATH=artifacts/engines/glintr100.bs1.opt8.max64.fp16.trt1016.engine
GPU_DEVICE_ID=0
INFERENCE_SLOT_COUNT=1
MATCH_THRESHOLD=0.55
MAX_IMAGE_BYTES=26214400

# Application
LOG_LEVEL=INFO
