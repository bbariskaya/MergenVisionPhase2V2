{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase 1 Bulk Enrollment Manifest",
  "type": "object",
  "required": ["schema_version", "source_namespace", "subjects"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "source_namespace": { "type": "string", "minLength": 1 },
    "subjects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["external_subject_key", "display_name", "images"],
        "properties": {
          "external_subject_key": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string", "minLength": 1 },
          "metadata": { "type": "object" },
          "images": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["relative_path"],
              "properties": {
                "relative_path": { "type": "string", "minLength": 1 },
                "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
                "holdout": { "type": "boolean", "default": false }
              }
            }
          }
        }
      }
    }
  }
}
