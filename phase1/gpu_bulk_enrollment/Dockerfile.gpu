# Multi-stage build for Phase 1 isolated GPU bulk enrollment.
# Builder produces a platform-specific wheel that includes the native CUDA
# extension.  Runtime stage installs only the wheel and CLI entrypoint.
#
# Images are pinned by SHA256 digest to keep builds reproducible.

# ------------------------------------------------------------------------------
# Builder stage
# ------------------------------------------------------------------------------
FROM nvidia/cuda:12.4.1-devel-ubuntu22.04@sha256:5645fec64549cc35930eee9d85aafd2b0006c0c3f22632be5a1d85e2604e9749 AS native-builder

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository -y ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3.12 python3.12-dev python3.12-venv cmake ninja-build g++ \
    && rm -rf /var/lib/apt/lists/*

RUN python3.12 -m venv /opt/venv && \
    /opt/venv/bin/pip install --no-cache-dir -U pip build pybind11

WORKDIR /build
COPY . /build

RUN /opt/venv/bin/python -m build --wheel --outdir /out

# ------------------------------------------------------------------------------
# Runtime stage
# ------------------------------------------------------------------------------
FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04@sha256:cff3a0d82d2c2b47bab252d67fa9b34a20ef4c50781d98501b5c7367ea9afd10

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PATH=/opt/venv/bin:$PATH

RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository -y ppa:deadsnakes/ppa \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3.12 python3.12-venv \
    && rm -rf /var/lib/apt/lists/*

RUN python3.12 -m venv /opt/venv && \
    /opt/venv/bin/pip install --no-cache-dir -U pip

COPY --from=native-builder /out/*.whl /tmp/wheels/
RUN /opt/venv/bin/pip install --no-cache-dir /tmp/wheels/*.whl && \
    rm -rf /tmp/wheels

WORKDIR /workspace/phase1/gpu_bulk_enrollment

# Copy runtime config, engines, and source into the image.
# The dataset is mounted read-only at /dataset and run artifacts at /artifacts.
COPY . /workspace/phase1/gpu_bulk_enrollment

VOLUME ["/dataset", "/artifacts"]

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD mv-phase1-bulk --version || exit 1

ENTRYPOINT ["mv-phase1-bulk"]
CMD ["--help"]
